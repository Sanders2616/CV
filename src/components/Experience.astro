---
import { experience } from '../data/content';
---

<section id="experience" class="section section-alt">
  <span class="section-num">02</span>
  <div class="container">
    <div class="reveal">
      <span class="section-label">Experiencia</span>
      <h2 class="section-title">Trayectoria</h2>
    </div>

    <div class="timeline">
      {experience.map((exp, i) => (
        <div class="exp-item reveal" style={`--reveal-delay: ${i * 130}ms`}>
          <div class="exp-line"></div>
          <div class="exp-dot"></div>
          <div class="exp-content">
            <div class="exp-header">
              <span class="exp-role">{exp.role}</span>
              <span class="exp-period">
                {exp.period}
                {exp.current && <span class="current-badge">⟳ Actual</span>}
              </span>
            </div>
            <div class="exp-company">{exp.company} · {exp.place}</div>
            <p class="exp-desc">{exp.description}</p>
            <div class="exp-tags">
              {exp.tags.map((t) => (
                <span class:list={['tag', t.kind]}>{t.label}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-alt {
    background: var(--color-bg2);
  }
  .timeline {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .exp-item {
    display: grid;
    grid-template-columns: 2px 1fr;
    gap: 0 20px;
    position: relative;
  }
  .exp-line {
    width: 2px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    border-radius: 2px;
    margin-top: 6px;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.2s;
  }
  .exp-item.is-visible .exp-line {
    transform: scaleY(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .exp-line { transform: scaleY(1); transition: none; }
  }
  .exp-dot {
    position: absolute;
    left: -3px;
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg2);
    box-shadow: 0 0 0 2px var(--color-accent);
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .exp-role {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: #fff;
  }
  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .current-badge {
    font-size: 0.62rem;
    padding: 2px 7px;
    border-radius: 100px;
    background: rgba(251, 191, 36, 0.08);
    box-shadow: inset 1px 1px 3px var(--neu-dark), inset -1px -1px 2px var(--neu-light);
    color: var(--color-yellow);
  }
  .exp-company {
    font-size: 0.85rem;
    color: var(--color-accent2);
    font-weight: 500;
    margin-bottom: 10px;
  }
  .exp-desc {
    font-size: 0.92rem;
    color: #b0aab8;
    line-height: 1.65;
    margin-bottom: 10px;
    max-width: 65ch;
  }
  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
</style>
