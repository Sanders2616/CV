---
import { about } from '../data/content';
---

<section id="about" class="section">
  <span class="section-num">01</span>
  <div class="container">
    <div class="reveal">
      <span class="section-label">{about.label}</span>
      <h2 class="section-title">Construyo software que resuelve, no que estorba</h2>
    </div>

    <div class="about-grid">
      <p class="about-text reveal">{about.paragraph}</p>

      <div class="about-stats">
        {about.stats.map((s, i) => {
          const isNumeric = !Number.isNaN(parseFloat(s.value));
          return (
            <div class="stat neu-card reveal" style={`--reveal-delay: ${i * 110}ms`}>
              <span class:list={['stat-value', 'gradient-text', isNumeric && 'counter', !isNumeric && 'infinity-pulse']}>
                {s.value}
              </span>
              <span class="stat-label">{s.label}</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    margin-top: 2.5rem;
    align-items: start;
  }
  .about-text {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stat {
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-value {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
  }
  .infinity-pulse {
    display: inline-block;
    animation: infinity-pulse 2.4s ease-in-out infinite;
  }
  @keyframes infinity-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    .infinity-pulse { animation: none; }
  }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-stats { flex-direction: row; flex-wrap: wrap; }
    .stat { flex: 1; min-width: 140px; }
  }
</style>
