---
import HeroCanvas from './HeroCanvas.svelte';
import RoleCycler from './RoleCycler.svelte';
import { person } from '../data/content';
---

<section id="top" class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <HeroCanvas client:load />
  <div class="hero-fade" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="badge">
      <span class="badge-dot"></span>
      {person.availability}
    </div>

    <h1 class="hero-name">{person.firstName}<br />{person.lastName}</h1>

    <div class="hero-role">
      <RoleCycler client:load />
    </div>

    <p class="hero-sub">{person.headline}</p>

    <div class="hero-cta">
      <a class="btn btn-primary" href="#experience">
        Ver experiencia
      </a>
      <a class="btn btn-ghost" href={`mailto:${person.email}`}>
        Escríbeme
      </a>
    </div>

    <div class="hero-meta">
      <span class="meta-item">{person.location}</span>
      <span class="meta-sep">/</span>
      <span class="meta-item">
        {person.languages.map((l) => `${l.label} ${l.level}`).join(' · ')}
      </span>
    </div>
  </div>

  <a class="scroll-hint" href="#about" aria-label="Bajar a la sección Sobre mí">
    <span>Scroll</span>
    <span class="scroll-line"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: -20%;
    z-index: 0;
    background:
      radial-gradient(40% 50% at 20% 25%, rgba(236, 72, 153, 0.14), transparent 70%),
      radial-gradient(35% 45% at 80% 20%, rgba(192, 132, 252, 0.12), transparent 70%),
      radial-gradient(45% 55% at 65% 80%, rgba(244, 114, 182, 0.1), transparent 70%);
    filter: blur(20px);
    animation: drift 18s ease-in-out infinite alternate;
  }
  @keyframes drift {
    0% { transform: translate3d(-2%, -1%, 0) scale(1); }
    100% { transform: translate3d(3%, 2%, 0) scale(1.08); }
  }

  .hero-fade {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-bg) 55%, transparent) 42%, transparent 75%),
      linear-gradient(0deg, var(--color-bg) 2%, transparent 30%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding-block: 7rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    background: rgba(236, 72, 153, 0.06);
    box-shadow: inset 2px 2px 5px var(--neu-dark), inset -2px -2px 5px var(--neu-light);
    color: var(--color-text);
    margin-bottom: 1.8rem;
  }
  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-green);
    box-shadow: 0 0 10px var(--color-green);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-name {
    font-size: clamp(2.6rem, 9vw, 5.5rem);
    font-weight: 700;
    line-height: 0.98;
    margin-bottom: 0.8rem;
    animation: name-glitch 7s ease-in-out infinite;
  }
  @keyframes name-glitch {
    0%, 95%, 100% { transform: translate(0, 0); filter: none; }
    95.5% {
      transform: translate(-2px, 1px);
      filter: drop-shadow(2px 0 0 rgba(244, 114, 182, 0.75)) drop-shadow(-2px 0 0 rgba(56, 189, 248, 0.75));
    }
    96.5% {
      transform: translate(2px, -1px);
      filter: drop-shadow(-2px 0 0 rgba(244, 114, 182, 0.75)) drop-shadow(2px 0 0 rgba(56, 189, 248, 0.75));
    }
    97.5% { transform: translate(0, 0); filter: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-name { animation: none; }
  }

  .hero-role {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.3rem, 4.5vw, 2.4rem);
    min-height: 1.4em;
    margin-bottom: 1.6rem;
  }

  .hero-sub {
    max-width: 42ch;
    color: var(--color-muted);
    font-size: clamp(1rem, 2.4vw, 1.15rem);
    margin-bottom: 2.4rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 2.6rem;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .meta-sep { opacity: 0.4; }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .scroll-line {
    width: 1px;
    height: 34px;
    background: linear-gradient(var(--color-muted), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.7); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }
  @media (max-width: 600px) {
    .scroll-hint { display: none; }
  }
</style>
