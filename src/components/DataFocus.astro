---
import { dataFocus } from '../data/content';
---

<section id="data" class="section">
  <span class="section-num">03</span>
  <div class="container">
    <div class="reveal">
      <span class="section-label">{dataFocus.label}</span>
      <h2 class="section-title">Donde vive el dato, ahí trabajo</h2>
    </div>

    <div class="data-panel neu-card reveal">
      <p class="data-blurb">{dataFocus.blurb}</p>
      <ul class="data-points">
        {dataFocus.points.map((p) => (
          <li>
            <span class="point-dot"></span>
            {p}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .data-panel {
    margin-top: 2.5rem;
    padding: 2.2rem clamp(1.5rem, 4vw, 2.6rem);
    background: linear-gradient(135deg, rgba(236, 72, 153, 0.06) 0%, rgba(192, 132, 252, 0.04) 100%);
  }
  .data-blurb {
    font-size: 1.1rem;
    color: var(--color-text);
    max-width: 70ch;
    margin-bottom: 1.8rem;
    line-height: 1.6;
  }
  .data-points {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem 1.5rem;
    list-style: none;
  }
  .data-points li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
  .point-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent2);
    margin-top: 7px;
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--color-accent2);
  }
  @media (max-width: 700px) {
    .data-points { grid-template-columns: 1fr; }
  }
</style>
