---
import { person } from '../data/content';

const channels = [
  { label: 'Email', value: person.email, href: `mailto:${person.email}` },
  { label: 'WhatsApp', value: person.whatsapp.display, href: person.whatsapp.href },
  { label: 'LinkedIn', value: person.linkedin.display, href: person.linkedin.href }
];
---

<section id="contact" class="section section-alt">
  <span class="section-num">06</span>
  <div class="container">
    <div class="contact-wrap reveal">
      <span class="section-label center">Contacto</span>
      <h2 class="contact-title">
        ¿Tienes un proyecto o una vacante? <span class="gradient-text">Hablemos.</span>
      </h2>
      <p class="contact-sub">
        {person.availability} — respondo rápido por WhatsApp o correo.
      </p>

      <div class="channels">
        {channels.map((c, i) => (
          <a class="channel neu-card reveal" style={`--reveal-delay: ${i * 110}ms`} href={c.href} target="_blank" rel="noopener noreferrer">
            <span class="channel-label">{c.label}</span>
            <span class="channel-value">{c.value}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-alt {
    background: var(--color-bg2);
    padding-bottom: 0;
  }
  .contact-wrap {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .section-label.center {
    justify-content: center;
  }
  .section-label.center::after {
    display: none;
  }
  .contact-title {
    font-size: clamp(2rem, 6vw, 3rem);
    margin-bottom: 1rem;
  }
  .contact-sub {
    color: var(--color-muted);
    max-width: 46ch;
    margin: 0 auto 2.6rem;
  }
  .channels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2.6rem;
    text-align: left;
  }
  .channel {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 1.1rem 1.3rem;
  }
  .channel-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
  }
  .channel-value {
    font-size: 0.92rem;
    font-weight: 500;
    word-break: break-word;
  }
  @media (max-width: 700px) {
    .channels { grid-template-columns: 1fr; }
  }
</style>
